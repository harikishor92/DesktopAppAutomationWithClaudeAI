<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  Home Page Test Suite
  Run with: mvn test -DsuiteXmlFile=src/test/resources/testng-hometest.xml
-->
<suite name="POS Home Page Test Suite" verbose="1">

    <listeners>
        <listener class-name="com.pos.automation.listeners.ExtentReportListener"/>
    </listeners>

    <test name="Home Page Test">
        <classes>
            <class name="com.pos.automation.tests.HomePageTest"/>
        </classes>
    </test>

</suite>